{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-journeys.schema.json",
  "title": "AgentJourneyProfile",
  "description": "Machine-readable role journey profile for agents using Boreal request-native work contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "journeys",
    "decisionRules",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_journey_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "journeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/journey"
      }
    },
    "decisionRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decisionRule"
      }
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "journey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "status",
        "userIntent",
        "primaryOutcome",
        "startWhen",
        "steps",
        "humanVisibleState",
        "requiredProfiles",
        "requiredAuth",
        "canonicalReads",
        "canonicalWrites",
        "stopConditions",
        "successEvidence",
        "nonAuthority"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "requester",
            "solver",
            "monitor",
            "optimizer",
            "payment",
            "onboarding"
          ]
        },
        "status": {
          "enum": [
            "live_public_read",
            "live_authenticated_http_contract",
            "live_validation_and_preparation",
            "live_account_session_payment_contract",
            "live_operator_review_handoff",
            "target_profile"
          ]
        },
        "userIntent": {
          "type": "string",
          "minLength": 1
        },
        "primaryOutcome": {
          "type": "string",
          "minLength": 1
        },
        "startWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/journeyStep"
          }
        },
        "humanVisibleState": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "requiredAuth": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stopConditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "successEvidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nonAuthority": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "journeyStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "agentAction",
        "readProfiles",
        "call",
        "renderForHuman",
        "continueWhen",
        "stopWhen",
        "canonicalReads",
        "canonicalWrites"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "agentAction": {
          "type": "string",
          "minLength": 1
        },
        "readProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "call": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "href", "status"],
          "properties": {
            "method": {
              "type": "string",
              "minLength": 1
            },
            "href": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "renderForHuman": {
          "type": "string"
        },
        "continueWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stopWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decisionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule", "appliesTo", "readBeforeActing"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readBeforeActing": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rootObject", "policyObject", "durableTruthObjects", "journeyProfileIsNot", "notRoots", "rules"],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "policyObject": {
          "const": "agentActionPolicy"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "journeyProfileIsNot": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
