{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-auth.schema.json",
  "title": "AgentAuthProfile",
  "description": "Machine-readable auth schemes, actor classes, scopes, approval rules, and write-boundary guidance for Boreal agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "preparationEndpoint",
    "authSchemes",
    "actorClasses",
    "scopes",
    "actionAuthRequirements",
    "approvalRules",
    "secretHandling",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_auth_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "preparationEndpoint": {
      "$ref": "#/$defs/preparationEndpoint"
    },
    "authSchemes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/authScheme"
      }
    },
    "actorClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actorClass"
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "actionAuthRequirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actionAuthRequirement"
      }
    },
    "approvalRules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "secretHandling": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "authArtifactsNotRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authArtifactsNotRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "authScheme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "standard",
        "officialSpecUrl",
        "status",
        "credentialKind",
        "useFor",
        "notFor"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "standard": {
          "type": "string",
          "minLength": 1
        },
        "officialSpecUrl": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "credentialKind": {
          "type": "string",
          "minLength": 1
        },
        "useFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "preparationEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "path",
        "schemaUrl",
        "returns",
        "canonicalReads",
        "canonicalWrites",
        "nonAuthority"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "returns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nonAuthority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actorClass": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "authScheme",
        "represents",
        "can",
        "cannot",
        "approvalBoundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "authScheme": {
          "type": "string",
          "minLength": 1
        },
        "represents": {
          "type": "string",
          "minLength": 1
        },
        "can": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cannot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvalBoundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "grants",
        "doesNotGrant",
        "requiredFor"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "grants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "doesNotGrant": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actionAuthRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionId",
        "intent",
        "availability",
        "authOptions",
        "requiredScopes",
        "humanApproval",
        "idempotencyRequired",
        "policyCheckpoint",
        "canonicalWrites"
      ],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "type": "string",
          "minLength": 1
        },
        "authOptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "humanApproval": {
          "type": "string",
          "minLength": 1
        },
        "idempotencyRequired": {
          "type": "boolean"
        },
        "policyCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
