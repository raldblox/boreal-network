{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-standards.schema.json",
  "title": "AgentStandardsProfile",
  "description": "Machine-readable standards matrix for Boreal agent discovery, contracts, auth, monitoring, protocols, payment, and error recovery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "standards",
    "resolutionOrder",
    "interoperabilityRules",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_standards_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "standards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/standard"
      }
    },
    "resolutionOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resolutionStep"
      }
    },
    "interoperabilityRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "status",
        "officialReferences",
        "borealUse",
        "currentBorealArtifacts",
        "currentArtifactVersions",
        "agentUse",
        "doNotUseFor"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "officialReferences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "borealUse": {
          "type": "string",
          "minLength": 1
        },
        "currentBorealArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "currentArtifactVersions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "agentUse": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "doNotUseFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "resolutionStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "read", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "read": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "standardsProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "standardsProfileIsNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
