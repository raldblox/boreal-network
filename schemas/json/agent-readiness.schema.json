{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-readiness.schema.json",
  "title": "AgentReadinessProfile",
  "description": "Machine-readable capability, UX-flow, standards, live-versus-target, and go/no-go profile for agents using Boreal request-native work contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "standardPlanes",
    "capabilityBands",
    "agentUxFlow",
    "goNoGoChecks",
    "currentLimitations",
    "nextImplementationPriorities",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_readiness_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "standardPlanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/standardPlane"
      }
    },
    "capabilityBands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capabilityBand"
      }
    },
    "agentUxFlow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/uxStage"
      }
    },
    "goNoGoChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/goNoGoCheck"
      }
    },
    "currentLimitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nextImplementationPriorities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/priority"
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "readinessIsNot",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readinessIsNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "standardPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "standard",
        "status",
        "useFor",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "standard": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "live_public_read",
            "live_contract_export",
            "live_contract_exports",
            "live_payment_profile",
            "live_schema_exports",
            "target_adapter_profile",
            "target_payment_profile"
          ]
        },
        "useFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "capabilityBand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "primaryAgentIntent",
        "status",
        "actions",
        "standards",
        "availableNow",
        "requiresBeforeUse",
        "stopOrEscalateWhen",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "primaryAgentIntent": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "live_public_read",
            "live_authenticated_http_contract",
            "live_recovery_profile",
            "live_contract_sandbox",
            "target_external_agent_auth",
            "target_write_sandbox_profile",
            "target_adapter_profile"
          ]
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "availableNow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiresBeforeUse": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopOrEscalateWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "uxStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "stage",
        "agentQuestion",
        "primaryProfile",
        "continueWhen",
        "stopWhen"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "agentQuestion": {
          "type": "string",
          "minLength": 1
        },
        "primaryProfile": {
          "type": "string",
          "format": "uri"
        },
        "continueWhen": {
          "type": "string",
          "minLength": 1
        },
        "stopWhen": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "goNoGoCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "appliesTo",
        "blocking",
        "passWhen",
        "failWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        },
        "passWhen": {
          "type": "string",
          "minLength": 1
        },
        "failWhen": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "priority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "target",
        "dependsOn"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
