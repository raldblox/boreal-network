{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/artifact.schema.json",
  "title": "Artifact",
  "description": "Canonical output or proof object attached to a Request and backed by a stable document, external, or object-storage reference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "key",
    "requestId",
    "kind",
    "title",
    "container",
    "createdBy",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "key": {
      "$ref": "common.schema.json#/$defs/key"
    },
    "requestId": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "fulfillmentId": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "stepId": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "kind": {
      "type": "string",
      "enum": [
        "brief",
        "plan",
        "draft",
        "file",
        "media",
        "delivery",
        "evidence",
        "receipt",
        "signature",
        "link"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "container": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "documentId",
            "documentKind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "document"
            },
            "documentId": {
              "$ref": "common.schema.json#/$defs/identifier"
            },
            "documentKind": {
              "type": "string",
              "enum": [
                "text",
                "code",
                "image",
                "sheet"
              ]
            },
            "mediaKind": {
              "type": "string",
              "enum": [
                "image",
                "audio",
                "video",
                "pdf",
                "binary",
                "archive",
                "other"
              ]
            },
            "mimeType": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "filename": {
              "type": "string",
              "minLength": 1,
              "maxLength": 260
            },
            "byteSize": {
              "type": "integer",
              "minimum": 0
            },
            "sha256": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "sourceUri": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "uri"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "external_ref"
            },
            "uri": {
              "type": "string",
              "format": "uri"
            },
            "mediaKind": {
              "type": "string",
              "enum": [
                "image",
                "audio",
                "video",
                "pdf",
                "binary",
                "archive",
                "other"
              ]
            },
            "mimeType": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "filename": {
              "type": "string",
              "minLength": 1,
              "maxLength": 260
            },
            "byteSize": {
              "type": "integer",
              "minimum": 0
            },
            "sha256": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "previewDocumentId": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "objectKey",
            "storageProvider"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "object_ref"
            },
            "objectKey": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "storageProvider": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "storageBucket": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "mediaKind": {
              "type": "string",
              "enum": [
                "image",
                "audio",
                "video",
                "pdf",
                "binary",
                "archive",
                "other"
              ]
            },
            "mimeType": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "filename": {
              "type": "string",
              "minLength": 1,
              "maxLength": 260
            },
            "byteSize": {
              "type": "integer",
              "minimum": 0
            },
            "sha256": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "previewDocumentId": {
              "$ref": "common.schema.json#/$defs/identifier"
            },
            "sourceUri": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      ]
    },
    "createdBy": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "createdAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updatedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    }
  }
}
