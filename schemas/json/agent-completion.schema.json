{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-completion.schema.json",
  "title": "AgentCompletionProfile",
  "description": "Machine-readable proof, artifact, completion-claim, and review-boundary rules for Boreal agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "completionRules",
    "proofPacket",
    "artifactGuidance",
    "reviewBoundaries",
    "completionSignals",
    "validationEndpoint",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_completion_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "completionRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/completionRule"
      }
    },
    "proofPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredFor",
        "fields",
        "qualityBar"
      ],
      "properties": {
        "requiredFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "qualityBar": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifactGuidance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactGuidance"
      }
    },
    "reviewBoundaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completionSignals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validationEndpoint": {
      "$ref": "#/$defs/validationEndpoint"
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "notCompletionTruth",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notCompletionTruth": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "completionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actionId",
        "claimState",
        "status",
        "meaning",
        "requiredTruth",
        "canonicalWrites",
        "notEnough",
        "nextHumanGate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "claimState": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "requiredTruth": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notEnough": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextHumanGate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifactGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactKind",
        "useFor",
        "mustInclude",
        "mustNotInclude"
      ],
      "properties": {
        "artifactKind": {
          "type": "string",
          "minLength": 1
        },
        "useFor": {
          "type": "string",
          "minLength": 1
        },
        "mustInclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mustNotInclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validationEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "path",
        "schemaUrl",
        "accepts",
        "returns",
        "nonAuthority"
      ],
      "properties": {
        "status": {
          "const": "live_validation_only"
        },
        "method": {
          "const": "POST"
        },
        "path": {
          "const": "/agents/completion/validate"
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "accepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nonAuthority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
