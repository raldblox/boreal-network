{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-action-preflight.schema.json",
  "title": "AgentActionPreflight",
  "description": "Validation-only request and response contract for checking whether an agent action has the visible prerequisites needed before attempting a real governed Boreal route. It does not grant permission, record approval, issue credentials, authorize payment, publish artifacts, propose commitments, mutate requests, prove completion, or create durable RequestEvent truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "acceptedActionIds",
    "request",
    "response",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "acceptedActionIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actionId"
      }
    },
    "request": {
      "$ref": "#/$defs/preflightRequest"
    },
    "response": {
      "$ref": "#/$defs/preflightResponse"
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "actionId": {
      "enum": [
        "inspect_public_requests",
        "make_request_for_human",
        "apply_to_request",
        "create_owner_private_fulfillment",
        "submit_artifact",
        "monitor_request",
        "run_public_solution",
        "optimize_request_brief"
      ]
    },
    "preflightRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionId"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionId": {
          "$ref": "#/$defs/actionId"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "representedActor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "reference": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "intendedUse": {
          "type": "string",
          "minLength": 1
        },
        "hasHumanApproval": {
          "type": "boolean"
        },
        "hasIdempotencyKey": {
          "type": "boolean"
        },
        "requestedScopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "payloadSummary": {
          "type": "string",
          "minLength": 1
        },
        "requestFit": {
          "$ref": "#/$defs/requestFit"
        },
        "requestFlowContext": {
          "$ref": "#/$defs/requestFlowContext"
        }
      }
    },
    "requestFit": {
      "type": "object",
      "additionalProperties": false,
      "description": "Visible request and selected Supply fingerprints used to fail fast before attempting apply_to_request or create_owner_private_fulfillment. Authoritative checks still happen on the governed mutation routes.",
      "properties": {
        "selectedSupplyId": {
          "type": "string",
          "minLength": 1
        },
        "selectedSupplyStatus": {
          "$ref": "common.schema.json#/$defs/supplyStatus"
        },
        "requestSupplyKinds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/supplyKind"
          }
        },
        "requestOutputKinds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/outputKind"
          }
        },
        "selectedSupplyKinds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/supplyKind"
          }
        },
        "selectedOutputKinds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/outputKind"
          }
        }
      }
    },
    "requestFlowContext": {
      "type": "object",
      "additionalProperties": false,
      "description": "Route-facing request-flow guidance copied from request constraints for validation-only preflight. It is not permission, worker assignment, Supply attachment, Fulfillment start, Artifact publication, payment authority, proof, or completion truth.",
      "properties": {
        "source": {
          "enum": [
            "request_constraints"
          ]
        },
        "entryStageId": {
          "anyOf": [
            {
              "$ref": "request-flow-stage-card-taxonomy.schema.json#/$defs/stageId"
            },
            {
              "type": "null"
            }
          ]
        },
        "cardKind": {
          "anyOf": [
            {
              "$ref": "request-flow-stage-card-taxonomy.schema.json#/$defs/cardKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "planStageIds": {
          "type": "array",
          "items": {
            "$ref": "request-flow-stage-card-taxonomy.schema.json#/$defs/stageId"
          }
        },
        "nextActionIntents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requestFlowActionIntent"
          }
        },
        "presetPlanStageIds": {
          "type": "array",
          "items": {
            "$ref": "request-flow-stage-card-taxonomy.schema.json#/$defs/stageId"
          }
        },
        "presetPlanRequiredBeforeExecution": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextCanonicalBoundary": {
          "$ref": "#/$defs/requestFlowCanonicalBoundary"
        },
        "nonAuthority": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "const": "request_flow_context_is_not_permission"
              }
            },
            {
              "contains": {
                "const": "no_worker_assignment_from_context"
              }
            },
            {
              "contains": {
                "const": "no_supply_attachment_from_context"
              }
            },
            {
              "contains": {
                "const": "no_fulfillment_started_from_context"
              }
            },
            {
              "contains": {
                "const": "no_artifact_published_from_context"
              }
            },
            {
              "contains": {
                "const": "no_payment_authorized_from_context"
              }
            },
            {
              "contains": {
                "const": "no_completion_proof_from_context"
              }
            }
          ],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requestFlowActionIntent": {
      "enum": [
        "create_request_draft",
        "propose_commitment",
        "authorize_funding",
        "attach_selected_supply",
        "start_governed_fulfillment",
        "submit_artifact",
        "monitor_activity",
        "create_private_run_request",
        "optimize_request_brief"
      ]
    },
    "requestFlowCanonicalBoundary": {
      "enum": [
        "Request",
        "Commitment",
        "Fulfillment",
        "Artifact",
        "NewRequestFromArtifact"
      ]
    },
    "preflightResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "status",
        "actionId",
        "acceptedActionIds",
        "actionAvailability",
        "actionName",
        "requiredAuth",
        "requiredScopes",
        "idempotencyRequired",
        "humanApprovalRequired",
        "representedActorRequired",
        "requestIdRequired",
        "payloadSummaryRecommended",
        "canonicalReads",
        "canonicalWrites",
        "requiredContracts",
        "entrypoints",
        "standards",
        "missingRequirements",
        "warnings",
        "nextSteps",
        "permissionGranted",
        "approvalRecorded",
        "credentialIssued",
        "paymentAuthorized",
        "completionProven",
        "durableWriteCreated",
        "canonicalBoundary"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "status": {
          "enum": [
            "preflight_passed",
            "preflight_failed"
          ]
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedActionIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actionId"
          }
        },
        "actionAvailability": {
          "enum": [
            "live_public_read",
            "live_authenticated_http_contract",
            "target_profile",
            "unknown"
          ]
        },
        "actionName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requiredAuth": {
          "type": [
            "string",
            "null"
          ]
        },
        "requiredScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "idempotencyRequired": {
          "type": "boolean"
        },
        "humanApprovalRequired": {
          "type": "boolean"
        },
        "representedActorRequired": {
          "type": "boolean"
        },
        "requestIdRequired": {
          "type": "boolean"
        },
        "payloadSummaryRecommended": {
          "type": "boolean"
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredContracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entrypoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingRequirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextSteps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissionGranted": {
          "const": false
        },
        "approvalRecorded": {
          "const": false
        },
        "credentialIssued": {
          "const": false
        },
        "paymentAuthorized": {
          "const": false
        },
        "completionProven": {
          "const": false
        },
        "durableWriteCreated": {
          "const": false
        },
        "canonicalBoundary": {
          "$ref": "#/$defs/canonicalBoundary"
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "preflightIsNot",
        "durableTruthObjects"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "preflightIsNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "enum": [
              "Request",
              "Commitment",
              "Fulfillment",
              "FulfillmentStep",
              "Artifact",
              "Transaction",
              "RequestEvent"
            ]
          }
        }
      }
    }
  }
}
