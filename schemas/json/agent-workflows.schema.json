{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-workflows.schema.json",
  "title": "AgentWorkflowCatalog",
  "description": "Machine-readable workflow catalog for agents using Boreal request-native discovery, policy, write, monitor, run, and optimize contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "policyRule",
    "resources",
    "workflows",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_workflow_catalog"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "policyRule": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "policyObject",
        "durableWrites",
        "notRoots"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "policyObject": {
          "const": "agentActionPolicy"
        },
        "durableWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "role",
        "status",
        "summary",
        "policyCheckpoint",
        "steps",
        "completionSignals",
        "idempotencyRequiredFor",
        "requiredResolverScopes",
        "forbiddenMoves"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "scout",
            "solver",
            "requester",
            "buyer",
            "optimizer"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "live_public_read",
            "live_authenticated_http_contract",
            "live_session_http_contract",
            "target_profile"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "policyCheckpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "href",
            "responseField",
            "requiredBeforeWrite"
          ],
          "properties": {
            "method": {
              "const": "GET"
            },
            "href": {
              "type": "string",
              "minLength": 1
            },
            "responseField": {
              "const": "agentActionPolicy"
            },
            "requiredBeforeWrite": {
              "type": "boolean"
            }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "completionSignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "idempotencyRequiredFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredResolverScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenMoves": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actionId",
        "method",
        "href",
        "auth",
        "canonicalReads",
        "canonicalWrites",
        "continueWhen",
        "stopWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "type": "string",
          "minLength": 1
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "continueWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
