{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-conformance.schema.json",
  "title": "AgentConformanceProfile",
  "description": "Machine-readable conformance checklist for agents validating Boreal discovery, auth, handoff, payment, proof, recovery, sandbox, and protocol boundaries before production use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "reportContract",
    "prerequisites",
    "checklists",
    "validationCommands",
    "productionReadinessGates",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_conformance_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "reportContract": {
      "$ref": "#/$defs/reportContract"
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checklists": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checklist"
      }
    },
    "validationCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationCommand"
      }
    },
    "productionReadinessGates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "conformanceProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conformanceProfileIsNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "reportContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "schemaUrl",
        "sampleUrl",
        "sampleFixturePath",
        "useFor",
        "requiredSections",
        "reportIsNot"
      ],
      "properties": {
        "status": {
          "const": "live_report_schema"
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "sampleUrl": {
          "type": "string",
          "format": "uri"
        },
        "sampleFixturePath": {
          "type": "string",
          "const": "fixtures/agent/conformance-report.sample.json"
        },
        "useFor": {
          "type": "string",
          "minLength": 1
        },
        "requiredSections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reportIsNot": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "intent",
        "requiredProfiles",
        "checks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "requiredProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "required",
        "passWhen",
        "failWhen",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "passWhen": {
          "type": "string",
          "minLength": 1
        },
        "failWhen": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "validationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "proves"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "proves": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
