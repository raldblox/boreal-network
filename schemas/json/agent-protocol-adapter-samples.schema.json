{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-protocol-adapter-samples.schema.json",
  "title": "AgentProtocolAdapterSamples",
  "description": "Target-only MCP, A2A, and x402 sample payload pack for mapping familiar protocols onto Boreal Request-native contracts without making adapters live.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "sourceProfiles",
    "samples",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "target_protocol_sample_pack"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sourceProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "samples": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/sample"
      }
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "standard",
        "status",
        "actionId",
        "transportConcept",
        "externalShape",
        "borealOperation",
        "promotionRules",
        "notAcceptedByProduction"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "standard": {
          "type": "string",
          "enum": [
            "mcp",
            "a2a",
            "x402"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "target_adapter_sample",
            "target_payment_sample"
          ]
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "transportConcept": {
          "type": "string",
          "minLength": 1
        },
        "externalShape": {
          "type": "object"
        },
        "borealOperation": {
          "$ref": "#/$defs/borealOperation"
        },
        "promotionRules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notAcceptedByProduction": {
          "const": true
        }
      }
    },
    "borealOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "canonicalReads",
        "canonicalWrites",
        "requiredScopes",
        "policyGate"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policyGate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "adapterSamplesAreNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adapterSamplesAreNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
