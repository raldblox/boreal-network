{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/in-house-worker-application-profile.schema.json",
  "title": "InHouseBorealWorkerApplicationProfile",
  "description": "Machine-readable profile for in-house Boreal workers scanning opened requests, applying through Commitment, and using owner-private direct Fulfillment only under trusted owner-scoped policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "sourceDecision",
    "liveWorkerSet",
    "namedAgentTemplates",
    "agentBoilerplate",
    "briefingQualificationTags",
    "scannerContract",
    "applicationPacket",
    "applicationLanes",
    "autoApprovalPolicy",
    "promptAssetBoundary",
    "canonicalBoundary",
    "examples"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "in_house_worker_application_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sourceDecision": {
      "$ref": "#/$defs/link"
    },
    "liveWorkerSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentLiveWorkerKeys",
        "targetOnlyWorkerKeys",
        "rules"
      ],
      "properties": {
        "currentLiveWorkerKeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "targetOnlyWorkerKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "namedAgentTemplates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedAgentTemplate"
      }
    },
    "agentBoilerplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requiredFiles",
        "requiredContracts",
        "requiredEnvironment",
        "taskPipelineRules"
      ],
      "properties": {
        "status": {
          "const": "template_contract"
        },
        "requiredFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredContracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredEnvironment": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/environmentBinding"
          }
        },
        "taskPipelineRules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "briefingQualificationTags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "purpose",
        "writeTargets",
        "rules"
      ],
      "properties": {
        "status": {
          "const": "planner_filter_inputs"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "writeTargets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scannerContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "reads",
        "writes",
        "cheapFilters",
        "wakePolicy",
        "authority"
      ],
      "properties": {
        "status": {
          "const": "read_only_projection"
        },
        "method": {
          "const": "GET"
        },
        "reads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/canonicalObject"
          }
        },
        "writes": {
          "type": "array",
          "maxItems": 0
        },
        "cheapFilters": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "wakePolicy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority": {
          "$ref": "#/$defs/nonAuthority"
        }
      }
    },
    "applicationPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requiredFields",
        "submissionPreflight",
        "mustReadBeforeSubmit",
        "mustNotContain"
      ],
      "properties": {
        "status": {
          "const": "local_until_submitted"
        },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "submissionPreflight": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "endpoint",
            "actionId",
            "directLaneActionId",
            "requiredStatus",
            "requiredBeforeMutation",
            "requiredInput",
            "routePolicyRecheck",
            "forbiddenClaimsBeforeAuthorizedMutation"
          ],
          "properties": {
            "endpoint": {
              "const": "/agents/actions/preflight"
            },
            "actionId": {
              "enum": [
                "apply_to_request",
                "create_owner_private_fulfillment"
              ]
            },
            "directLaneActionId": {
              "const": "create_owner_private_fulfillment"
            },
            "requiredStatus": {
              "const": "preflight_passed"
            },
            "requiredBeforeMutation": {
              "const": true
            },
            "requiredInput": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "representedActor",
                "hasHumanApproval",
                "hasIdempotencyKey",
                "requestedScopes",
                "directLaneRequestedScopes",
                "payloadSummaryRequired"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "representedActor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "kind",
                    "referencePattern"
                  ],
                  "properties": {
                    "kind": {
                      "const": "agent"
                    },
                    "referencePattern": {
                      "type": "string",
                      "pattern": "^boreal-agent:"
                    }
                  }
                },
                "hasHumanApproval": {
                  "const": true
                },
                "hasIdempotencyKey": {
                  "const": true
                },
                "requestedScopes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "enum": [
                      "commitments:propose",
                      "fulfillments:create"
                    ]
                  }
                },
                "directLaneRequestedScopes": {
                  "type": "array",
                  "contains": {
                    "const": "fulfillments:create"
                  },
                  "items": {
                    "enum": [
                      "fulfillments:create"
                    ]
                  }
                },
                "payloadSummaryRequired": {
                  "const": true
                }
              }
            },
            "routePolicyRecheck": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "requestDetailRequired",
                "agentActionPolicyRequired",
                "selectedSupplyRequired",
                "ownerPrivateAutoApprovalRequiredForDirectLane",
                "mutationScopeIfResolverBearer"
              ],
              "properties": {
                "requestDetailRequired": {
                  "const": true
                },
                "agentActionPolicyRequired": {
                  "const": true
                },
                "selectedSupplyRequired": {
                  "const": true
                },
                "ownerPrivateAutoApprovalRequiredForDirectLane": {
                  "const": true
                },
                "mutationScopeIfResolverBearer": {
                  "type": "array",
                  "contains": {
                    "const": "commitments:propose"
                  },
                  "items": {
                    "enum": [
                      "commitments:propose",
                      "fulfillments:create"
                    ]
                  }
                }
              }
            },
            "forbiddenClaimsBeforeAuthorizedMutation": {
              "type": "array",
              "minItems": 5,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "mustReadBeforeSubmit": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mustNotContain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "applicationLanes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/applicationLane"
      }
    },
    "autoApprovalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scope",
        "allowedEffects",
        "forbiddenEffects",
        "requiredGates"
      ],
      "properties": {
        "status": {
          "const": "owner_scoped_policy"
        },
        "scope": {
          "const": "trusted_first_party_supply_only"
        },
        "allowedEffects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbiddenEffects": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredGates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "promptAssetBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supportAssetKinds",
        "cannotBeFrontpageSupplyUntil",
        "rules"
      ],
      "properties": {
        "supportAssetKinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cannotBeFrontpageSupplyUntil": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "profileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/canonicalObject"
          }
        },
        "profileIsNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/example"
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "path",
        "status"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonicalObject": {
      "type": "string",
      "enum": [
        "Actor",
        "Supply",
        "Request",
        "RequestParticipant",
        "Commitment",
        "Fulfillment",
        "FulfillmentStep",
        "Artifact",
        "Transaction",
        "RequestEvent"
      ]
    },
    "agentStatus": {
      "type": "string",
      "enum": [
        "live_template",
        "target_template"
      ]
    },
    "environmentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "requiredFor",
        "secret"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "requiredFor": {
          "type": "string",
          "minLength": 1
        },
        "secret": {
          "const": true
        }
      }
    },
    "namedAgentTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentKey",
        "uniqueName",
        "displayName",
        "status",
        "apiRoute",
        "workerKey",
        "framework",
        "promotionGates",
        "supplyBinding",
        "modelBindings",
        "toolBindings",
        "qualificationTags",
        "taskPipeline",
        "nonAuthority"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "live_template"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "promotionGates": {
                "properties": {
                  "state": {
                    "const": "live_backed"
                  },
                  "openBlockers": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "target_template"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "promotionGates": {
                "properties": {
                  "state": {
                    "const": "target_blocked"
                  },
                  "openBlockers": {
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      ],
      "properties": {
        "agentKey": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "uniqueName": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/agentStatus"
        },
        "apiRoute": {
          "type": "string",
          "pattern": "^/api/boreal-agents/[a-z0-9][a-z0-9-]*$"
        },
        "workerKey": {
          "type": "string",
          "minLength": 1
        },
        "framework": {
          "$ref": "#/$defs/agentFramework"
        },
        "promotionGates": {
          "$ref": "#/$defs/agentPromotionGates"
        },
        "supplyBinding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "supplyKind",
            "providerRef"
          ],
          "properties": {
            "required": {
              "const": true
            },
            "supplyKind": {
              "$ref": "#/$defs/borealSupplyKind"
            },
            "providerRef": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "modelBindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "provider",
              "purpose",
              "env",
              "models"
            ],
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "openai",
                  "runway"
                ]
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              },
              "env": {
                "type": "string",
                "minLength": 1
              },
              "models": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "toolBindings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "qualificationTags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "actorKinds",
            "supplyKinds",
            "outputKinds",
            "executionKinds",
            "skipWhen"
          ],
          "properties": {
            "actorKinds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/borealActorKind"
              }
            },
            "supplyKinds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/borealSupplyKind"
              }
            },
            "outputKinds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/borealOutputKind"
              }
            },
            "executionKinds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/borealRequestExecutionKind"
              }
            },
            "skipWhen": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "taskPipeline": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/agentTaskStep"
          }
        },
        "nonAuthority": {
          "$ref": "#/$defs/nonAuthority"
        }
      }
    },
    "borealActorKind": {
      "type": "string",
      "enum": [
        "human",
        "agent",
        "tool",
        "organization",
        "runtime"
      ]
    },
    "borealSupplyKind": {
      "type": "string",
      "enum": [
        "agent_worker",
        "ai_automation",
        "automation_builder",
        "desktop_runtime",
        "digital_product",
        "documentation_support",
        "field_inspection",
        "field_verification",
        "generalist",
        "hardware_ops",
        "human_service",
        "local_runner",
        "migration_lead",
        "operations_build",
        "operations_support",
        "operator",
        "pickup_dropoff",
        "provider_capability",
        "qa_documentation",
        "reporting_support",
        "runtime_executor",
        "team_service",
        "video_generation"
      ]
    },
    "borealOutputKind": {
      "type": "string",
      "enum": [
        "automation_build",
        "delivery",
        "delivery_confirmation",
        "draft",
        "file",
        "handoff_doc",
        "handoff_receipt",
        "inspection_report",
        "issue_log",
        "media",
        "migration_plan",
        "operator_training",
        "photo_evidence",
        "serial_inventory",
        "signature",
        "verification_note",
        "video",
        "workflow_build",
        "workflow_map"
      ]
    },
    "borealRequestExecutionKind": {
      "type": "string",
      "enum": [
        "instant_delivery",
        "hybrid_tool_room",
        "provider_api",
        "local_runtime",
        "hybrid_human_agent",
        "human_request_room",
        "agent_request_room",
        "runtime_request_room",
        "specialist_request_room"
      ]
    },
    "agentPromotionEvidenceKind": {
      "type": "string",
      "enum": [
        "supply_factory",
        "execution_contract",
        "proof_path",
        "failure_fixtures",
        "route_level_mutation_tests"
      ]
    },
    "agentPromotionGates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "requiredEvidence",
        "evidenceRefs",
        "openBlockers",
        "rules"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "live_backed",
            "target_blocked"
          ]
        },
        "requiredEvidence": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/agentPromotionEvidenceKind"
          },
          "allOf": [
            {
              "contains": {
                "const": "supply_factory"
              }
            },
            {
              "contains": {
                "const": "execution_contract"
              }
            },
            {
              "contains": {
                "const": "proof_path"
              }
            },
            {
              "contains": {
                "const": "failure_fixtures"
              }
            },
            {
              "contains": {
                "const": "route_level_mutation_tests"
              }
            }
          ]
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "label",
              "path",
              "status"
            ],
            "properties": {
              "kind": {
                "$ref": "#/$defs/agentPromotionEvidenceKind"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "implemented",
                  "tested",
                  "missing",
                  "target_required"
                ]
              }
            }
          }
        },
        "openBlockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "agentFramework": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "routePattern",
        "routeMode",
        "supportedActions",
        "boilerplateFiles",
        "taskPipelineRules",
        "nonAuthority"
      ],
      "properties": {
        "id": {
          "const": "boreal_named_agent_v1"
        },
        "version": {
          "const": 1
        },
        "routePattern": {
          "const": "/api/boreal-agents/{agentKey}"
        },
        "routeMode": {
          "const": "preparation_only"
        },
        "supportedActions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "read_template",
              "scan_request_candidates",
              "prepare_application"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "read_template"
              }
            },
            {
              "contains": {
                "const": "scan_request_candidates"
              }
            },
            {
              "contains": {
                "const": "prepare_application"
              }
            }
          ]
        },
        "boilerplateFiles": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "taskPipelineRules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nonAuthority": {
          "type": "array",
          "minItems": 7,
          "items": {
