{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/request.schema.json",
  "title": "Request",
  "description": "Canonical durable demand-side root object for Boreal Network.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "key",
    "status",
    "createdBy",
    "owner",
    "brief",
    "seeking",
    "budget",
    "activeRefs",
    "latest",
    "parallelFulfillmentAllowed",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "key": {
      "$ref": "common.schema.json#/$defs/key"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/requestStatus"
    },
    "createdBy": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "owner": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "outputKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "seeking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actorKinds",
        "supplyKinds"
      ],
      "properties": {
        "actorKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/actorKind"
          }
        },
        "supplyKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teamMode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "fixed",
            "range",
            "open"
          ]
        },
        "currency": {
          "$ref": "common.schema.json#/$defs/currencyCode"
        },
        "fixedAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "minAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "maxAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "activeRefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeCommitmentId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "activeFulfillmentId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "latestArtifactId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "latestTransactionId": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    },
    "latest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "lastEventAt": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "lastActor": {
          "$ref": "common.schema.json#/$defs/actorRef"
        }
      }
    },
    "parallelFulfillmentAllowed": {
      "type": "boolean",
      "default": false
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "createdAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updatedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "openedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "fundedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "deliveredAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "completedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "cancelledAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "failedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "budget": {
            "properties": {
              "mode": {
                "const": "fixed"
              }
            },
            "required": [
              "mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "budget": {
            "required": [
              "currency",
              "fixedAmount"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "budget": {
            "properties": {
              "mode": {
                "const": "range"
              }
            },
            "required": [
              "mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "budget": {
            "required": [
              "currency",
              "minAmount",
              "maxAmount"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "funding_required"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "activeRefs": {
            "required": [
              "activeCommitmentId"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "funded",
              "in_progress",
              "waiting_for_owner",
              "delivered",
              "completed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "activeRefs": {
            "required": [
              "activeCommitmentId"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "in_progress",
              "waiting_for_owner",
              "delivered",
              "completed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "activeRefs": {
            "required": [
              "activeFulfillmentId"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "completedAt"
        ]
      }
    }
  ]
}
