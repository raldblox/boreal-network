{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/request.schema.json",
  "title": "Request",
  "description": "Canonical durable demand-side root object for Boreal Network.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "key",
    "status",
    "createdBy",
    "owner",
    "brief",
    "visibility",
    "routing",
    "parallelFulfillmentAllowed",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "key": {
      "$ref": "common.schema.json#/$defs/key"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/requestStatus"
    },
    "createdBy": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "owner": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public"
      ]
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "outputKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "description": "Optional human labels. Useful for display or owner-provided labeling, but not the primary structured matching surface.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "seeking": {
      "description": "Structured matching intent. May be partial while the request is still being formed.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actorKinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/actorKind"
          }
        },
        "supplyKinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teamMode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "routing": {
      "description": "Owner-controlled routing preferences for private request execution.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredSupplyId": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "fixed",
            "range",
            "open"
          ]
        },
        "currency": {
          "$ref": "common.schema.json#/$defs/currencyCode"
        },
        "fixedAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "minAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "maxAmount": {
          "$ref": "common.schema.json#/$defs/moneyValue"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "deadline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targetAt": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "activeRefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeCommitmentId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "activeFulfillmentId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "latestArtifactId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "latestTransactionId": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    },
    "latest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "lastEventAt": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "lastActor": {
          "$ref": "common.schema.json#/$defs/actorRef"
        }
      }
    },
    "derived": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidatePool",
        "matchCandidates",
        "roleSlots",
        "phases",
        "noMicrotaskExplosion",
        "outcomeClaims",
        "leadRanking",
        "roleMatches",
        "assignmentProposal",
        "replanReasons",
        "missingDetails",
        "readiness",
        "executionProfile",
        "embodiedConstraintSet",
        "verificationPlan",
        "planCollapseRisk",
        "clarificationNeeded"
      ],
      "properties": {
        "routeFamily": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "executionKind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "paymentMode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "matchingMode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "candidatePool": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "leadRole": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "roleSlots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "roleKey",
              "title",
              "requiredActorKinds",
              "preferredSupplyKinds",
              "required"
            ],
            "properties": {
              "roleKey": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200
              },
              "requiredActorKinds": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "$ref": "common.schema.json#/$defs/actorKind"
                }
              },
              "preferredSupplyKinds": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": {
                "type": "boolean"
              },
              "summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "phaseKey",
              "title",
              "summary",
              "roleKeys",
              "requiredEvidenceClaims"
            ],
            "properties": {
              "phaseKey": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "roleKeys": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "requiredEvidenceClaims": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "noMicrotaskExplosion": {
          "type": "boolean"
        },
        "outcomeClaims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claimKey",
              "summary",
              "source",
              "nonSubstitutable",
              "proofRequired"
            ],
            "properties": {
              "claimKey": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "brief",
                  "output_kind",
                  "execution",
                  "verification"
                ]
              },
              "nonSubstitutable": {
                "type": "boolean"
              },
              "proofRequired": {
                "type": "boolean"
              }
            }
          }
        },
        "matchCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "supplyId",
              "source",
              "overallScore",
              "leadScore",
              "roleScores",
              "summary"
            ],
            "properties": {
              "supplyId": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "source": {
                "type": "string",
                "enum": [
                  "retrieved",
                  "preferred_supply"
                ]
              },
              "overallScore": {
                "type": "number"
              },
              "leadScore": {
                "type": "number"
              },
              "roleScores": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "roleKey",
                    "score",
                    "confidence"
                  ],
                  "properties": {
                    "roleKey": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "score": {
                      "type": "number"
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "moderate",
                        "high"
                      ]
                    }
                  }
                }
              },
              "summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "leadRanking": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "roleKey",
              "source",
              "status",
              "confidence",
              "summary"
            ],
            "properties": {
              "roleKey": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "supplyId": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "source": {
                "type": "string",
                "enum": [
                  "planner",
                  "candidate_pool",
                  "preferred_supply",
                  "fulfillment"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "open",
                  "candidate",
                  "selected",
                  "attached"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "low",
                  "moderate",
                  "high"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "roleMatches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "roleKey",
              "required",
              "source",
              "status",
              "confidence",
              "summary"
            ],
            "properties": {
              "roleKey": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "required": {
                "type": "boolean"
              },
              "supplyId": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "source": {
                "type": "string",
                "enum": [
                  "planner",
                  "candidate_pool",
                  "preferred_supply",
                  "fulfillment"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "open",
                  "candidate",
                  "selected",
                  "attached"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "low",
                  "moderate",
                  "high"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "assignmentProposal": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state",
            "summary",
            "lead",
            "support"
          ],
          "properties": {
            "state": {
              "type": "string",
              "enum": [
                "unfilled",
                "candidate_pool",
                "selected_supply",
                "execution_attached"
              ]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "lead": {
              "anyOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "roleKey",
                    "required",
                    "source",
                    "status",
                    "confidence",
                    "summary"
                  ],
                  "properties": {
                    "roleKey": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "supplyId": {
                      "$ref": "common.schema.json#/$defs/identifier"
                    },
                    "source": {
                      "type": "string",
                      "enum": [
                        "planner",
                        "candidate_pool",
                        "preferred_supply",
                        "fulfillment"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "open",
                        "candidate",
                        "selected",
                        "attached"
                      ]
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "moderate",
                        "high"
                      ]
                    },
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              ]
            },
            "support": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "roleKey",
                  "required",
                  "source",
                  "status",
                  "confidence",
                  "summary"
                ],
                "properties": {
                  "roleKey": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "supplyId": {
                    "$ref": "common.schema.json#/$defs/identifier"
                  },
                  "source": {
                    "type": "string",
                    "enum": [
                      "planner",
                      "candidate_pool",
                      "preferred_supply",
                      "fulfillment"
                    ]
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "open",
                      "candidate",
                      "selected",
                      "attached"
                    ]
                  },
                  "confidence": {
                    "type": "string",
                    "enum": [
                      "low",
                      "moderate",
                      "high"
                    ]
                  },
                  "summary": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "replanReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "missingDetails": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state",
            "summary",
            "readyForOpen",
            "readyForMatch"
          ],
          "properties": {
            "state": {
              "type": "string",
              "enum": [
                "collecting_brief",
                "ready_to_open",
                "ready_to_match"
              ]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "readyForOpen": {
              "type": "boolean"
            },
            "readyForMatch": {
              "type": "boolean"
            }
          }
        },
        "routeSummary": {
          "type": "string",
          "minLength": 1
        },
        "executionProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "executionModes",
            "requiresHumanPresence",
            "requiresLocalAccess",
            "requiresVerifiedEvidence",
            "requiresScheduling",
            "requiresGeography",
            "riskTier"
          ],
          "properties": {
            "executionModes": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "remote_digital",
                  "remote_sync",
                  "onsite_visit",
                  "field_inspection",
                  "pickup_dropoff",
                  "witnessed_handoff"
                ]
              }
            },
            "requiresHumanPresence": {
              "type": "boolean"
            },
            "requiresLocalAccess": {
              "type": "boolean"
            },
            "requiresVerifiedEvidence": {
              "type": "boolean"
            },
            "requiresScheduling": {
              "type": "boolean"
            },
            "requiresGeography": {
              "type": "boolean"
            },
            "riskTier": {
              "type": "string",
              "enum": [
                "low",
                "moderate",
                "high"
              ]
            }
          }
        },
        "embodiedConstraintSet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requiresEmbodiedHandling",
            "executionModes",
            "timeWindows",
            "accessRequirements",
            "safetyRequirements",
            "verificationRequirements",
            "requiresHumanPresence",
            "requiresLocalAccess",
            "requiresVerifiedEvidence",
            "requiresWitness"
          ],
          "properties": {
            "requiresEmbodiedHandling": {
              "type": "boolean"
            },
            "executionModes": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "remote_digital",
                  "remote_sync",
                  "onsite_visit",
                  "field_inspection",
                  "pickup_dropoff",
                  "witnessed_handoff"
                ]
              }
            },
            "serviceLocation": {
              "type": "string",
              "minLength": 1
            },
            "timeWindows": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "accessRequirements": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "safetyRequirements": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "verificationRequirements": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "requiresHumanPresence": {
              "type": "boolean"
            },
            "requiresLocalAccess": {
              "type": "boolean"
            },
            "requiresVerifiedEvidence": {
              "type": "boolean"
            },
            "requiresWitness": {
              "type": "boolean"
            }
          }
        },
        "verificationPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requiredArtifactKinds",
            "requiredEvidenceClaims",
            "mustHaveOwnerAcceptance",
            "mustHaveLocationSignal",
            "mustHaveSignature"
          ],
          "properties": {
            "requiredArtifactKinds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "brief",
                  "plan",
                  "draft",
                  "file",
                  "media",
                  "delivery",
                  "evidence",
                  "receipt",
                  "signature",
                  "link"
                ]
              }
            },
            "requiredEvidenceClaims": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "mustHaveOwnerAcceptance": {
              "type": "boolean"
            },
            "mustHaveLocationSignal": {
              "type": "boolean"
            },
            "mustHaveSignature": {
              "type": "boolean"
            }
          }
        },
        "planCollapseRisk": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "riskLevel",
            "reasons"
          ],
          "properties": {
            "riskLevel": {
              "type": "string",
              "enum": [
                "low",
                "moderate",
                "high"
              ]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "clarificationNeeded": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "missingDetails",
            "reasons"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "missingDetails": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "parallelFulfillmentAllowed": {
      "type": "boolean",
      "default": false
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "createdAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updatedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "openedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "fundedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "deliveredAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "completedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "cancelledAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "failedAt": {
      "$ref": "common.schema.json#/$defs/timestamp"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "open",
              "funding_required",
              "funded",
              "in_progress",
              "waiting_for_owner",
              "delivered",
              "completed",
              "cancelled",
              "failed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "brief": {
            "required": [
              "title",
              "body"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "budget": {
            "properties": {
              "mode": {
                "const": "fixed"
              }
            },
            "required": [
              "mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "budget": {
            "required": [
              "currency",
