{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-http.schema.json",
  "title": "AgentHttpProfile",
  "description": "Machine-readable unified HTTP reference profile for current agent-callable Boreal routes, auth, scopes, idempotency, and canonical write boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "contractSources",
    "requestConventions",
    "routeFamilies",
    "intentToHttp",
    "nonHttpIntentFallbacks",
    "safetyRules",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_http_reference_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "contractSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contractSource"
      }
    },
    "requestConventions": {
      "$ref": "#/$defs/requestConventions"
    },
    "routeFamilies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/routeFamily"
      }
    },
    "intentToHttp": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/intentToHttp"
      }
    },
    "nonHttpIntentFallbacks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonHttpIntentFallback"
      }
    },
    "safetyRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "contractSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "url",
        "covers"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "live_openapi_export"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "covers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requestConventions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseUrl",
        "contentTypes",
        "authSchemes",
        "requiredHeaders",
        "standardErrors",
        "preflightOrder"
      ],
      "properties": {
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "contentTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authSchemes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredHeaders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "standardErrors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "preflightOrder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "routeFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "sourceOpenApi",
        "routes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "live_public_read",
            "live_authenticated_http_contract"
          ]
        },
        "sourceOpenApi": {
          "type": "string",
          "format": "uri"
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/httpRoute"
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "actionIds",
        "auth",
        "requiredScopes",
        "idempotencyRequired",
        "canonicalReads",
        "canonicalWrites"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "actionIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "auth": {
          "type": "string",
          "minLength": 1
        },
        "requiredScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "idempotencyRequired": {
          "type": "boolean"
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "intentToHttp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionId",
        "toolId",
        "status",
        "method",
        "href",
        "auth",
        "idempotencyRequired",
        "canonicalReads",
        "canonicalWrites",
        "preflight",
        "stopWhen"
      ],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "toolId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "type": "string",
          "minLength": 1
        },
        "idempotencyRequired": {
          "type": "boolean"
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preflight": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "nonHttpIntentFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionId",
        "status",
        "reason",
        "profileUrl"
      ],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "profileUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "httpProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "httpProfileIsNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
