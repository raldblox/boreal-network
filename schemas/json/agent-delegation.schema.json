{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-delegation.schema.json",
  "title": "AgentDelegationProfile",
  "description": "Machine-readable human-first delegation profile for Boreal agents, consent screens, scoped authority, revocation, and per-action approval boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "delegationModes",
    "humanConsentFlows",
    "consentReceipt",
    "revocation",
    "policyBoundary",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_human_delegation_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "delegationModes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/delegationMode"
      }
    },
    "humanConsentFlows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/humanConsentFlow"
      }
    },
    "consentReceipt": {
      "$ref": "#/$defs/consentReceipt"
    },
    "revocation": {
      "$ref": "#/$defs/revocation"
    },
    "policyBoundary": {
      "$ref": "#/$defs/policyBoundary"
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "delegationMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "standard",
        "credentialKind",
        "humanConsentRequired",
        "useFor",
        "notFor",
        "secretsSharedWithAgent",
        "productionWriteCapability"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "live_public_read",
            "live_account_session",
            "live_resolver_bearer",
            "target_external_agent_auth",
            "target_operator_review"
          ]
        },
        "standard": {
          "type": "string",
          "minLength": 1
        },
        "credentialKind": {
          "type": "string",
          "minLength": 1
        },
        "humanConsentRequired": {
          "type": "boolean"
        },
        "useFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secretsSharedWithAgent": {
          "type": "boolean"
        },
        "productionWriteCapability": {
          "type": "boolean"
        }
      }
    },
    "humanConsentFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actionId",
        "representedHuman",
        "promptTitle",
        "decisionQuestion",
        "requiredScopes",
        "authOptions",
        "requiredBeforeAgentMayDo",
        "visibleToHuman",
        "canonicalReads",
        "canonicalWritesIfApproved",
        "approvalExpiresWhen",
        "revocationPath",
        "stopWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "actionId": {
          "type": "string",
          "enum": [
            "make_request_for_human",
            "apply_to_request",
            "submit_artifact",
            "monitor_request",
            "run_public_solution",
            "optimize_request_brief"
          ]
        },
        "representedHuman": {
          "type": "string",
          "minLength": 1
        },
        "promptTitle": {
          "type": "string",
          "minLength": 1
        },
        "decisionQuestion": {
          "type": "string",
          "minLength": 1
        },
        "requiredScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authOptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredBeforeAgentMayDo": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "visibleToHuman": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWritesIfApproved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvalExpiresWhen": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "revocationPath": {
          "type": "string",
          "minLength": 1
        },
        "stopWhen": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "consentReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requiredFields",
        "mustInclude",
        "mustNotInclude"
      ],
      "properties": {
        "status": {
          "const": "support_record_not_business_truth"
        },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "mustInclude": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "mustNotInclude": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "liveRoutes",
        "targetRoutes",
        "rules"
      ],
      "properties": {
        "liveRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/revocationRoute"
          }
        },
        "targetRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/revocationRoute"
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "revocationRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "method",
        "path",
        "useFor"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "useFor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policyBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requiredCheckpoint",
        "rules"
      ],
      "properties": {
        "status": {
          "const": "derived_per_request"
        },
        "requiredCheckpoint": {
          "const": "agentActionPolicy"
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "delegationProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "delegationProfileIsNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
