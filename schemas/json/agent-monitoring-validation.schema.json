{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-monitoring-validation.schema.json",
  "title": "AgentMonitoringValidation",
  "description": "Validation-only request and response contract for checking agent monitoring plans before cursor polling or target signed webhook receiver implementation. It does not grant permission, read request activity, create subscriptions, activate push delivery, create heartbeat events, authorize payment, prove completion, or create durable RequestEvent truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "acceptedModes",
    "acceptedEscalationTriggers",
    "request",
    "response",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "acceptedModes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/monitorMode"
      }
    },
    "acceptedEscalationTriggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/escalationTrigger"
      }
    },
    "request": {
      "$ref": "#/$defs/monitoringValidationRequest"
    },
    "response": {
      "$ref": "#/$defs/monitoringValidationResponse"
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "monitorMode": {
      "enum": [
        "poll_cursor",
        "signed_webhook_target"
      ]
    },
    "escalationTrigger": {
      "enum": [
        "owner_review_needed",
        "missing_or_unreviewable_proof",
        "payment_uncertain",
        "blocked_fulfillment",
        "private_access_or_scope_missing",
        "stale_activity"
      ]
    },
    "monitoringValidationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "monitor"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "monitor": {
          "$ref": "#/$defs/monitorPlan"
        }
      }
    },
    "monitorPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requestId",
        "storesCursor",
        "createsHeartbeatEvents",
        "claimsCompletion",
        "includesPrivatePayloads",
        "escalationTriggers"
      ],
      "properties": {
        "mode": {
          "$ref": "#/$defs/monitorMode"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "unknown"
          ]
        },
        "hasRequestAccess": {
          "type": "boolean"
        },
        "requestedScopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "afterSequence": {
              "type": "number",
              "minimum": 0
            },
            "nextAfterSequence": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "poll": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "intervalSeconds": {
              "type": "number",
              "minimum": 0
            },
            "limit": {
              "type": "number",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "webhook": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "callbackUrl": {
              "type": "string",
              "minLength": 1
            },
            "signatureVersion": {
              "const": "v1"
            },
            "timestampToleranceSeconds": {
              "type": "number",
              "minimum": 0,
              "maximum": 300
            },
            "canVerifySignature": {
              "type": "boolean"
            }
          }
        },
        "escalationTriggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/escalationTrigger"
          }
        },
        "storesCursor": {
          "type": "boolean"
        },
        "createsHeartbeatEvents": {
          "type": "boolean"
        },
        "claimsCompletion": {
          "type": "boolean"
        },
        "includesPrivatePayloads": {
          "type": "boolean"
        }
      }
    },
    "monitoringValidationResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "status",
        "acceptedModes",
        "acceptedEscalationTriggers",
        "pollingReady",
        "signedWebhookTargetReady",
        "subscriptionPersisted",
        "pushDeliveryActivated",
        "heartbeatEventCreated",
        "requestEventWritten",
        "completionProven",
        "paymentAuthorized",
        "permissionGranted",
        "durableWriteCreated",
        "summary",
        "missingFields",
        "warnings",
        "nextSteps",
        "canonicalBoundary"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "status": {
          "enum": [
            "validation_passed",
            "validation_failed"
          ]
        },
        "acceptedModes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monitorMode"
          }
        },
        "acceptedEscalationTriggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/escalationTrigger"
          }
        },
        "pollingReady": {
          "type": "boolean"
        },
        "signedWebhookTargetReady": {
          "type": "boolean"
        },
        "subscriptionPersisted": {
          "const": false
        },
        "pushDeliveryActivated": {
          "const": false
        },
        "heartbeatEventCreated": {
          "const": false
        },
        "requestEventWritten": {
          "const": false
        },
        "completionProven": {
          "const": false
        },
        "paymentAuthorized": {
          "const": false
        },
        "permissionGranted": {
          "const": false
        },
        "durableWriteCreated": {
          "const": false
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "missingFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextSteps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalBoundary": {
          "$ref": "#/$defs/canonicalBoundary"
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "activityTruthObject",
        "validationIsNot",
        "durableTruthObjects"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "activityTruthObject": {
          "const": "RequestEvent"
        },
        "validationIsNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "enum": [
              "Request",
              "Commitment",
              "Fulfillment",
              "FulfillmentStep",
              "Artifact",
              "Transaction",
              "RequestEvent"
            ]
          }
        }
      }
    }
  }
}
