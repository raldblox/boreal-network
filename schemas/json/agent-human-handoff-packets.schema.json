{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-human-handoff-packets.schema.json",
  "title": "AgentHumanHandoffPacketExamples",
  "description": "Checked example packet set for agents rendering human-first Boreal approval, review, escalation, and payment handoffs without turning those packets into canonical truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "sourceProfiles",
    "packetContract",
    "examples",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_handoff_packet_examples"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sourceProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "packetContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredFields",
        "humanDecisionMustBe",
        "agentMustNot"
      ],
      "properties": {
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "humanDecisionMustBe": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "agentMustNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/handoffPacket"
      }
    },
    "canonicalBoundary": {
      "$ref": "#/$defs/canonicalBoundary"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "handoffPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actionId",
        "handoffMomentId",
        "representedHuman",
        "claimState",
        "status",
        "userFacingTitle",
        "userFacingSummary",
        "decisionQuestion",
        "allowedHumanDecisions",
        "visibleEvidence",
        "canonicalReads",
        "canonicalWritesIfApproved",
        "approvalRequired",
        "stopRules",
        "notAuthority",
        "example"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "handoffMomentId": {
          "type": "string",
          "minLength": 1
        },
        "representedHuman": {
          "type": "string",
          "enum": [
            "buyer_or_owner",
            "buyer_or_reviewer",
            "buyer_or_funder",
            "owner_solver_or_operator",
            "any_human_participant"
          ]
        },
        "claimState": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "example_only"
        },
        "userFacingTitle": {
          "type": "string",
          "minLength": 1
        },
        "userFacingSummary": {
          "type": "string",
          "minLength": 1
        },
        "decisionQuestion": {
          "type": "string",
          "minLength": 1
        },
        "allowedHumanDecisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "visibleEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceLine"
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWritesIfApproved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "stopRules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notAuthority": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "example": {
          "$ref": "#/$defs/examplePayload"
        }
      }
    },
    "evidenceLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "sourceObject",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "sourceObject": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "examplePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "actorSummary",
        "latestKnownTruth",
        "proposedNextStep",
        "humanDecisionOptions",
        "agentWillNotDo"
      ],
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "actorSummary": {
          "type": "string",
          "minLength": 1
        },
        "latestKnownTruth": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proposedNextStep": {
          "type": "string",
          "minLength": 1
        },
        "humanDecisionOptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "agentWillNotDo": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "handoffPacketsAreNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoffPacketsAreNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
