{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-ux.schema.json",
  "title": "AgentUxProfile",
  "description": "Machine-readable human-first process and UX profile for agents using Boreal request-native work contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "entrypoints",
    "processStages",
    "interactionSurfaces",
    "humanFirstRules",
    "claimStateLabels",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_agent_ux_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entrypoint"
      }
    },
    "processStages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/processStage"
      }
    },
    "interactionSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/interactionSurface"
      }
    },
    "humanFirstRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/humanFirstRule"
      }
    },
    "claimStateLabels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claimStateLabel"
      }
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "uxProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uxProfileIsNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "standard",
        "primaryUrl",
        "fallbackUrls",
        "useWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "standard": {
          "type": "string",
          "minLength": 1
        },
        "primaryUrl": {
          "type": "string",
          "format": "uri"
        },
        "fallbackUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "useWhen": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "processStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "order",
        "title",
        "status",
        "userIntent",
        "agentGoal",
        "primaryActionIds",
        "readProfiles",
        "renderForHuman",
        "canonicalReads",
        "canonicalWrites",
        "continueWhen",
        "stopWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "userIntent": {
          "type": "string",
          "minLength": 1
        },
        "agentGoal": {
          "type": "string",
          "minLength": 1
        },
        "primaryActionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "renderForHuman": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "continueWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "interactionSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "userFacingName",
        "purpose",
        "renderFrom",
        "canonicalReads",
        "canonicalWrites",
        "humanDecisionRequired"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "userFacingName": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "renderFrom": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "humanDecisionRequired": {
          "type": "boolean"
        }
      }
    },
    "humanFirstRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rule",
        "stopWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "stopWhen": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "claimStateLabel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "say",
        "requiredTruth",
        "notEnough"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "say": {
          "type": "string",
          "minLength": 1
        },
        "requiredTruth": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notEnough": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "live_public_read",
        "live_authenticated_http_contract"
      ]
    }
  }
}
