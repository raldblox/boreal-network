{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boreal.work/schemas/json/agent-monitoring.schema.json",
  "title": "AgentMonitoringProfile",
  "description": "Machine-readable cursor polling, stale-state detection, escalation, webhook-boundary, and no-heartbeat-noise monitoring profile for Boreal agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "name",
    "description",
    "resources",
    "pollingBaseline",
    "validationEndpoint",
    "preparationEndpoint",
    "cursorRules",
    "watchSignals",
    "escalationTriggers",
    "webhookBoundary",
    "canonicalBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "live_monitoring_profile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "pollingBaseline": {
      "$ref": "#/$defs/pollingBaseline"
    },
    "validationEndpoint": {
      "$ref": "#/$defs/monitorEndpoint"
    },
    "preparationEndpoint": {
      "$ref": "#/$defs/monitorEndpoint"
    },
    "cursorRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "watchSignals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/watchSignal"
      }
    },
    "escalationTriggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/escalationTrigger"
      }
    },
    "webhookBoundary": {
      "$ref": "#/$defs/webhookBoundary"
    },
    "canonicalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootObject",
        "durableTruthObjects",
        "monitoringProfileIsNot",
        "notRoots",
        "rules"
      ],
      "properties": {
        "rootObject": {
          "const": "Request"
        },
        "durableTruthObjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "monitoringProfileIsNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "pollingBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "routeTemplate",
        "cursorField",
        "ordering",
        "defaultLimit",
        "canonicalReads",
        "canonicalWrites"
      ],
      "properties": {
        "status": {
          "const": "live_cursor_polling"
        },
        "method": {
          "const": "GET"
        },
        "routeTemplate": {
          "type": "string",
          "minLength": 1
        },
        "cursorField": {
          "type": "string",
          "minLength": 1
        },
        "ordering": {
          "type": "string",
          "minLength": 1
        },
        "defaultLimit": {
          "type": "integer",
          "minimum": 1
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "monitorEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "path",
        "schemaUrl",
        "canonicalReads",
        "canonicalWrites",
        "nonAuthority"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "acceptedModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nonAuthority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rule",
        "failWhen"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "failWhen": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "watchSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "readFrom",
        "agentAction",
        "doNotClaim"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "readFrom": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentAction": {
          "type": "string",
          "minLength": 1
        },
        "doNotClaim": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "escalationTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "trigger",
        "escalationTarget",
        "packetFields"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "escalationTarget": {
          "type": "string",
          "minLength": 1
        },
        "packetFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "webhookBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "liveBaseline",
        "headers",
        "receiverRules"
      ],
      "properties": {
        "status": {
          "const": "target_signed_push_profile"
        },
        "liveBaseline": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receiverRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
