# required
# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required
# neon postgres connection string
POSTGRES_URL=****

# optional for local non-vercel development if you keep the AI Gateway path
AI_GATEWAY_API_KEY=****

# optional until boreal web needs file uploads or blob persistence
BLOB_READ_WRITE_TOKEN=****

# optional until rate limiting or ephemeral coordination is enabled
# upstash or another redis-compatible provider can supply this
REDIS_URL=****
