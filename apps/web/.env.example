# required
# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required
# neon postgres connection string
POSTGRES_URL=****

# optional for local non-vercel development if you keep the AI Gateway path
AI_GATEWAY_API_KEY=****

# optional until boreal web needs file uploads or blob persistence
BLOB_READ_WRITE_TOKEN=****

# optional until Boreal-managed Runway supplies are enabled
RUNWAYML_API_SECRET=****
RUNWAYML_API_VERSION=2024-11-06

# optional until rate limiting or ephemeral coordination is enabled
# upstash or another redis-compatible provider can supply this
REDIS_URL=****

# required for production WebAuthn MFA origin hardening
# local development may use http://localhost:3000 and rp id localhost
# use the actual apps/web Vercel production origin or custom alias
NEXT_PUBLIC_APP_URL=https://network.boreal.work
WEBAUTHN_ORIGIN=https://network.boreal.work
WEBAUTHN_RP_ID=network.boreal.work
WEBAUTHN_ALLOWED_ORIGINS=https://network.boreal.work

# required before problem-intel promotion writes are enabled
# generate a random operator-only token and keep it server-side only
PROBLEM_INTEL_EDIT_TOKEN=****
