  "scenarioId": "eval-complex-human-planning-and-match",
  "description": "Complex human-led operations migration with AI-assisted support should match a human lead first, then propose a bounded team plan.",
  "requestInput": {
    "actor": {
      "kind": "human",
      "id": "actor_nadia_cho",
      "displayName": "Nadia Cho"
