          "Idempotency-Key": "00000000-0000-4000-8000-000000000101"
        },
        "body": {
          "kind": "proposal",
          "summary": "I can complete the requested automation cleanup and submit proof artifacts.",
          "terms": {
            "fundingRequired": true,
            "amountMode": "fixed",
            "currency": "USD",
            "fixedAmount": 250,
